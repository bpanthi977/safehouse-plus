    attr: int = 0
    indent: int = 0
    inline: bool = False  # render detail on the same line as text (name → value)


def effective_workdir(state: State) -> str:
    return state.workdir or str(Path.cwd())


def home_ancestors() -> List[str]:
    home = Path.home()
    return [str(home.parent), str(home)]


def category_paths(name: str) -> List[str]:
    if name == "Home ancestors":
        return home_ancestors()
    for cat, _mode, paths in DEFAULT_PATH_CATEGORIES:
        if cat == name:
            return paths
    return []


def category_of(path: str) -> str | None:
    """Return the default category a path belongs to, or None."""
    if path in home_ancestors():
        return "Home ancestors"
    for name, _mode, paths in DEFAULT_PATH_CATEGORIES:
        if path in paths:
            return name
    return None


def paths_for_override(state: State, name: str) -> List[str]:
    if name == "Workdir":
        return [effective_workdir(state)]
    if name.startswith(("/", "~")):
        return [name]
    return category_paths(name)


def override_allow_paths(state: State) -> tuple[List[str], List[str]]:
    ro: List[str] = []
    rw: List[str] = []
    for name, mode in state.path_overrides.items():
        paths = paths_for_override(state, name)
        if mode == "ro":
            ro.extend(paths)
        elif mode == "rw":
            rw.extend(paths)
    return unique(ro), unique(rw)


def default_mode(path_or_category: str) -> str:
    if path_or_category == "Workdir":
        return "rw"
    if path_or_category == str(CONFIG_PATH):
        return "deny"
    if path_or_category == "Home ancestors" or path_or_category in home_ancestors():
        return "meta"
    for name, mode, paths in DEFAULT_PATH_CATEGORIES:
        if path_or_category == name or path_or_category in paths:
            return mode
    return "off"


def current_default_mode(state: State, path_or_category: str) -> str:
    return state.path_overrides.get(path_or_category, default_mode(path_or_category))


def tag(mode: str) -> str:
    return f"[{mode}]" if mode not in {"default", "off"} else f"[{mode}]"


def path_mode(state: State, path: str) -> str:
    if path in state.rw_paths:
        return "rw"
    if path in state.ro_paths:
        return "ro"
    if path in state.deny_paths:
        return "deny"
    return "off"


def set_path_mode(state: State, path: str, mode: str) -> None:
    if path not in state.paths:
        state.paths.append(path)
    for xs in (state.ro_paths, state.rw_paths, state.deny_paths):
        while path in xs:
            xs.remove(path)
    if mode == "ro":
        state.ro_paths.append(path)
    elif mode == "rw":
        state.rw_paths.append(path)
    elif mode == "deny":
        state.deny_paths.append(path)


def cycle_user_path(state: State, path: str) -> None:
    mode = path_mode(state, path)
    set_path_mode(state, path, ACCESS_CYCLE[(ACCESS_CYCLE.index(mode) + 1) % len(ACCESS_CYCLE)])


def next_default_mode(current: str, name: str) -> str:
    nxt = DEFAULT_CYCLE[(DEFAULT_CYCLE.index(current) + 1) % len(DEFAULT_CYCLE)]
    # An explicit mode that equals the row's default is visually identical to
    # "default" (no override), so skip it to avoid a no-op Space press.
    if nxt != "default" and nxt == default_mode(name):
        nxt = DEFAULT_CYCLE[(DEFAULT_CYCLE.index(nxt) + 1) % len(DEFAULT_CYCLE)]
    return nxt


def cycle_default(state: State, name: str) -> None:
    mode = state.path_overrides.get(name, "default")
    nxt = next_default_mode(mode, name)
    if nxt == "default":
        state.path_overrides.pop(name, None)
    else:
        state.path_overrides[name] = nxt


def cycle_category(state: State, name: str) -> None:
    paths = category_paths(name)
    mode = state.path_overrides.get(name, "default")
    nxt = next_default_mode(mode, name)
    if nxt == "default":
        state.path_overrides.pop(name, None)
        for p in paths:
            state.path_overrides.pop(p, None)
    else:
        state.path_overrides[name] = nxt
        for p in paths:
            state.path_overrides[p] = nxt


def mode_attr(mode: str) -> int:
    return {
        "rw": color(CP_GOOD, curses.A_BOLD),
        "ro": color(CP_ACCENT),
        "meta": color(CP_MUTED),
        "deny": color(CP_BAD, curses.A_BOLD),
        "off": color(CP_MUTED),
        "change": color(CP_WARN),
        "pass": color(CP_GOOD),
        "file": color(CP_ACCENT),
        "missing": color(CP_BAD),
        "all": color(CP_WARN),
    }.get(mode.strip("[]"), 0)


def env_value(name: str) -> tuple[str, str]:
    return ("pass", os.environ.get(name, "")) if name in os.environ else ("missing", "not set in parent environment")


_sourced_env_cache: dict[tuple[str, float], dict[str, str]] = {}


def sourced_env(state: State) -> dict[str, str]:
    if not (state.env_file_enabled and state.env_file):
        return {}
    path = os.path.expanduser(state.env_file)
    # The env file is trusted shell input sourced by bash, so it may have side
    # effects.  Cache by (path, mtime) so we only re-source when it changes,
    # rather than spawning bash on every redraw of the Environment tab.
    try:
        mtime = os.path.getmtime(path)
    except OSError:
        mtime = 0.0
    cache_key = (path, mtime)
    if cache_key in _sourced_env_cache:
        return _sourced_env_cache[cache_key]
    script = 'set -a; source "$1"; env -0'
    base = {name: os.environ.get(name, "") for name in DEFAULT_ENV_VARS if name in os.environ}
    try:
        p = subprocess.run(["/bin/bash", "-c", script, "bash", path],
                           env=base, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, timeout=5)
    except Exception:
        return {}
    result: dict[str, str] = {}
    for item in p.stdout.decode(errors="replace").split("\0"):
        if "=" in item:
            k, v = item.split("=", 1)
            result[k] = v
    sourced = {k: v for k, v in result.items() if base.get(k) != v or k not in base}
    _sourced_env_cache[cache_key] = sourced
    return sourced


def changes_rows(state: State, rows: List[Row], scope: str) -> None:
    changes: List[str] = []
    if scope == "network":
        if not state.network:
            changes.append("+ DENY network*")
        if state.docker_socket:
            changes.append("+ ALLOW Docker socket access")
        if state.podman_socket:
            changes.append("+ ALLOW Podman socket access")
        if state.ssh_agent_socket:
            changes.append("+ ALLOW SSH agent socket access")
    elif scope == "paths":
        for p in unique(state.rw_paths + state.ro_paths + state.deny_paths):
            changes.append(f"+ {path_mode(state, p).upper()} {p}")
        for p, m in state.path_overrides.items():
            if m == default_mode(p):
                continue
            # A member path whose owning category carries the same override is
            # already covered by the category's own change line; don't repeat it.
            cat = category_of(p)
            if cat and cat != p and state.path_overrides.get(cat) == m:
                continue
            changes.append(f"{p}: {default_mode(p).upper()} → {m.upper()}")
    elif scope == "features":
        for f in state.enabled:
            changes.append(f"+ ENABLE {f}")
    if changes:
        rows.append(Row("heading", "Changes from default", selectable=False))
        rows.extend(Row("info", c, tag="change", selectable=False) for c in changes)


def rows_for(state: State, tab: str, dirty: bool) -> List[Row]:
    rows: List[Row] = []
    if tab == "Run":
        rows += [Row("heading", "Command", selectable=False), Row("info", shell_join(state.command) or "(none)", selectable=False)]
        rows.append(Row("heading", "Actions", selectable=False))
        if LAST_RESUME_COMMAND:
            rows += [Row("resume", "Resume detected session", shell_join(LAST_RESUME_COMMAND), tag="resume")]
        rows += [
            Row("run", "Run / Restart command", tag="run"),
            Row("edit_command", "Edit command", tag="edit"),
            Row("export", "Write generated policy to file", tag="export"),
            Row("save", "Save and Quit" + (" *" if dirty else ""), tag="save"),
            Row("discard", "Discard and Quit", tag="discard"),
            Row("heading", "Generated sandbox command", selectable=False),
            Row("info", generated_command_line(state), selectable=False),
        ]
        profile_text = state.profile_text()
        if profile_text:
            rows += [
                Row("heading", "Generated profile (<generated-profile>)", selectable=False),
                Row("info", profile_text.rstrip("\n"), selectable=False),
            ]
        return rows

    if tab == "Network":
        rows.append(Row("heading", "Network controls", selectable=False))
        rows += [
            Row("network", "Allow network traffic", tag="x" if state.network else " "),
            Row("docker_socket", "Allow Docker socket access", "/var/run/docker.sock\n~/.docker/run/docker.sock", tag="x" if state.docker_socket else " "),
            Row("podman_socket", "Allow Podman socket access", "/run/podman/podman.sock\n~/.local/share/containers/podman/machine/podman.sock", tag="x" if state.podman_socket else " "),
            Row("ssh_agent_socket", "Allow SSH agent socket access", "SSH_AUTH_SOCK", tag="x" if state.ssh_agent_socket else " "),
        ]
        changes_rows(state, rows, "network")
        return rows

    if tab == "Paths":
        rows.append(Row("heading", "User path rules", selectable=False))
        rows.append(Row("add_path", "Add path rule", tag="add"))
        custom = sorted(set(state.paths + state.ro_paths + state.rw_paths + state.deny_paths))
        if custom:
            rows += [Row("path:" + p, p, tag=path_mode(state, p)) for p in custom]
        rows.append(Row("heading", "Default writable paths", selectable=False))
        rows.append(Row("default:Workdir", "Workdir", effective_workdir(state), tag=current_default_mode(state, "Workdir")))
        for name, mode, paths in DEFAULT_PATH_CATEGORIES:
            if mode == "rw":
                add_category_rows(state, rows, name)
        rows.append(Row("heading", "Default read-only paths", selectable=False))
        for name, mode, paths in DEFAULT_PATH_CATEGORIES:
            if mode == "ro":
                add_category_rows(state, rows, name)
        rows.append(Row("heading", "Default metadata-only paths", selectable=False))
        add_category_rows(state, rows, "Home ancestors")
        rows.append(Row("heading", "Default denied paths", selectable=False))
        rows.append(Row("default:" + str(CONFIG_PATH), "Project sandbox config", str(CONFIG_PATH), tag=current_default_mode(state, str(CONFIG_PATH))))
        changes_rows(state, rows, "paths")
        return rows

    if tab == "Environment":
        rows.append(Row("heading", "Environment mode", selectable=False))
        rows.append(Row("env_full", "Pass full environment", tag="x" if state.env_mode == "full" else " "))
        rows.append(Row("env_file", "Load trusted environment file (sourced by bash)", state.env_file, tag="x" if state.env_file_enabled and state.env_file else " "))
        rows.append(Row("heading", "Extra env-pass variables", selectable=False))
        if state.env_mode == "full":
            rows.append(Row("info", "Ignored while full environment is enabled", tag="info", selectable=False))
        else:
            rows.append(Row("add_env", "Add variable", tag="add"))
            rows += [Row("env_pass:" + name, name, env_value(name)[1], tag=env_value(name)[0], inline=True) for name in state.env_pass]
        rows.append(Row("heading", "Passed variables", selectable=False))
        if state.env_mode == "full":
            rows.append(Row("info", "Full parent environment will be passed to the command", tag="all", selectable=False))
            rows.append(Row("heading", "Preview", selectable=False))
            for name in list(os.environ)[:12]:
                rows.append(Row("info", name, os.environ.get(name, ""), tag="env", selectable=False, inline=True))
            rows.append(Row("info", "...", "more variables not shown", tag="env", selectable=False, inline=True))
        else:
            for name in DEFAULT_ENV_VARS:
                rows.append(Row("info", name, os.environ.get(name, ""), tag="pass", selectable=False, inline=True))
            for name, value in sourced_env(state).items():
                if name not in DEFAULT_ENV_VARS:
                    rows.append(Row("info", name, value, tag="file", selectable=False, inline=True))
        return rows

    rows = []
    for heading, entries in FEATURE_GROUPS:
        rows.append(Row("heading", heading, selectable=False))
        for label, feature in entries:
            rows.append(Row("feature:" + feature, label, tag="x" if feature in state.enabled else " "))
    changes_rows(state, rows, "features")
    return rows


def add_category_rows(state: State, rows: List[Row], name: str) -> None:
    rows.append(Row("category:" + name, name, tag=current_default_mode(state, name)))
    if name in state.expanded_path_categories:
        for p in category_paths(name):
            rows.append(Row("default:" + p, p, tag=current_default_mode(state, p), indent=2))


def generated_command_line(state: State) -> str:
    # The live runner uses a temporary append-profile for safehouse+ rules
    # (network denies, socket grants, config-file protection).  The UI shows a
    # stable placeholder instead of a path that would be deleted after redraw.
    argv = [SAFEHOUSE] + state.safehouse_args("<generated-profile>") + ["--"] + state.command
    return shell_join(argv)


def selectable_indices(rows: List[Row]) -> List[int]:
    return [i for i, row in enumerate(rows) if row.selectable]


def clamp_selection(rows: List[Row], idx: int) -> int:
    choices = selectable_indices(rows)
    if not choices:
        return 0
    if idx in choices:
        return idx
    return min(choices, key=lambda i: abs(i - idx))


def move_selection(rows: List[Row], idx: int, delta: int) -> int:
    choices = selectable_indices(rows)
    if not choices:
        return 0
    pos = choices.index(clamp_selection(rows, idx))
    return choices[max(0, min(len(choices) - 1, pos + delta))]


def export_policy(stdscr, state: State) -> None:
    path = prompt(stdscr, "Export policy to", "safehouse.sb", complete_path=True)
    if not path:
        return
    profile = state.make_append_profile()
    try:
        args = [SAFEHOUSE] + state.safehouse_args(profile) + [f"--output={os.path.expanduser(path)}"]
        show_text(stdscr, "export policy", run_capture(args) or f"Wrote {path}")
    finally:
        if profile:
            try: os.unlink(profile)
            except OSError: pass


def activate_row(stdscr, state: State, row: Row) -> bool:
    key = row.key
    if key == "resume" and LAST_RESUME_COMMAND:
        launch_program(stdscr, state, LAST_RESUME_COMMAND)
    elif key == "run":
        launch_program(stdscr, state)
    elif key == "edit_command":
        s = prompt(stdscr, "Command", shell_join(state.command))
        if s is not None:
            parsed = parse_command(s)
            if parsed is not None:
                state.command = parsed
    elif key == "export":
        export_policy(stdscr, state)
    elif key == "save":
        state.save(); return True
    elif key == "discard":
        return True
    elif key in {"network", "docker_socket", "podman_socket", "ssh_agent_socket"}:
        setattr(state, {"network":"network", "docker_socket":"docker_socket", "podman_socket":"podman_socket", "ssh_agent_socket":"ssh_agent_socket"}[key], not getattr(state, key))
    elif key == "add_path":
        s = prompt(stdscr, "Add path rule", "", complete_path=True)
        if s:
            set_path_mode(state, s, "rw")
    elif key.startswith("path:"):
        cycle_user_path(state, key[5:])
    elif key.startswith("category:"):
        name = key[9:]
        if name in state.expanded_path_categories:
            state.expanded_path_categories.remove(name)
        else:
            state.expanded_path_categories.append(name)
    elif key.startswith("default:"):
        cycle_default(state, key[8:])
    elif key == "env_full":
        state.env_mode = "sanitized" if state.env_mode == "full" else "full"
    elif key == "env_file":
        s = prompt(stdscr, "Trusted env file", state.env_file, complete_path=True)
        if s is not None:
            state.env_file = s
            state.env_file_enabled = bool(s)
    elif key == "add_env":
        s = prompt(stdscr, "Environment variable name", "")
        if s and s not in state.env_pass:
            state.env_pass.append(s)
    elif key.startswith("env_pass:"):
        old = key[9:]
        s = prompt(stdscr, "Environment variable name", old)
        if s:
            state.env_pass[state.env_pass.index(old)] = s
    elif key.startswith("feature:"):
        f = key[8:]
        if f in state.enabled:
            state.enabled.remove(f)
        else:
            state.enabled.append(f); state.enabled.sort()
    return False


def delete_or_reset(state: State, row: Row) -> bool:
    key = row.key
    if key == "discard":
        return True
    if key == "env_full":
        state.env_mode = "sanitized"
    elif key == "env_file":
        state.env_file = ""
        state.env_file_enabled = False
    elif key.startswith("env_pass:"):
        name = key[9:]
        if name in state.env_pass:
            state.env_pass.remove(name)
    elif key.startswith("path:"):
        path = key[5:]
        set_path_mode(state, path, "off")
        while path in state.paths:
            state.paths.remove(path)
    elif key.startswith("default:"):
        state.path_overrides.pop(key[8:], None)
    elif key.startswith("category:"):
        name = key[9:]
        state.path_overrides.pop(name, None)
        for p in category_paths(name):
            state.path_overrides.pop(p, None)
    return False


def draw_tabs(stdscr, active: int) -> None:
    addstr(stdscr, 0, 0, "safehouse+", color(CP_TITLE, curses.A_BOLD))
    x = 1
    for i, name in enumerate(TABS):
        y = 2
        text = f" {name} "
        attr = color(CP_SELECTED if i == active else CP_TITLE, curses.A_BOLD if i == active else 0)
        addstr(stdscr, y, x, text, attr)
        x += len(text) + 2
    addstr(stdscr, 3, 0, "─" * max(0, curses.COLS - 1), color(CP_MUTED))


def wrapped_lines(text: str, width: int) -> List[str]:
    if width <= 1:
        return [text]
    lines: List[str] = []
    for part in text.splitlines() or [""]:
        lines.extend(textwrap.wrap(part, width=width, break_long_words=False, break_on_hyphens=False) or [""])
    return lines


def draw_rows(stdscr, rows: List[Row], idx: int, top: int) -> None:
    y = 5
    max_y = curses.LINES - 2
    for n, row in enumerate(rows[top:], start=top):
        if y >= max_y:
            break
        if row.key == "heading":
            addstr(stdscr, y, 0, row.text, color(CP_TITLE, curses.A_BOLD)); y += 1; continue
        selected = n == idx
        prefix_attr = color(CP_SELECTED) if selected else 0
        addstr(stdscr, y, 0, "> " if selected else "  ", prefix_attr)
        x = 2 + row.indent
        if row.tag:
            display_tag = f"[{row.tag}]" if len(row.tag) == 1 else f"[{row.tag}]"
            addstr(stdscr, y, x, display_tag, mode_attr(row.tag)); x += len(display_tag) + 1
        text_attr = (color(CP_TITLE, curses.A_BOLD) if selected else row.attr)
        if row.key == "info":
            text_attr |= color(CP_MUTED)

        text_width = max(1, curses.COLS - x - 1)
        text_lines = wrapped_lines(row.text, text_width)
        addstr(stdscr, y, x, text_lines[0], text_attr)
        for extra in text_lines[1:]:
            y += 1
            if y >= max_y: break
            addstr(stdscr, y, x, extra, text_attr)

        if row.detail and y < max_y:
            details = row.detail.splitlines()
            first_x = min(max(32, x + min(len(text_lines[-1]), 28) + 2), max(2, curses.COLS - 30))
            for i, d in enumerate(details):
                # Inline rows (name → value) keep the first detail line on the
                # same row as the label; everything else drops it below.
                if i > 0 or (text_lines and not row.inline):
                    y += 1
                    if y >= max_y: break
                for j, line in enumerate(wrapped_lines(d, max(1, curses.COLS - first_x - 1))):
                    if j > 0:
                        y += 1
                        if y >= max_y: break
                    addstr(stdscr, y, first_x, line, color(CP_MUTED))
        y += 1


def footer_for(tab: str, row: Row) -> str:
    if tab == "Run":
        return "Enter/Space activate · ←/→ switch tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save · D discard"
    if tab == "Network":
        return "Enter/Space toggle · ←/→ switch tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save · D discard"
    if tab == "Paths":
        if row.key.startswith("category:"):
            return "Space cycle · Enter expand/collapse · D reset · ←/→ tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save"
        return "Space cycle · Enter expand/edit · D delete/reset · ←/→ tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save"
    if tab == "Environment" and row.key == "info":
        return "Read-only · ←/→ tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save"
    if tab == "Environment":
        return "Space toggle · Enter edit/add · D delete/reset · ←/→ tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save"
    return "Space/Enter toggle · ←/→ tabs · Ctrl-p/Ctrl-n move · q/Ctrl-C save"


def main_ui(stdscr, state: State, original: State | None = None) -> None:
    init_colors(); curses.curs_set(0); stdscr.keypad(True)
    active = 0
    idx_by_tab = {tab: 0 for tab in TABS}
    top_by_tab = {tab: 0 for tab in TABS}
    original_snapshot = (original or copy.deepcopy(state)).settings_dict()
    while True:
        tab = TABS[active]
        dirty = state.settings_dict() != original_snapshot
        rows = rows_for(state, tab, dirty)
        idx = clamp_selection(rows, idx_by_tab[tab])
        idx_by_tab[tab] = idx
        height = max(1, curses.LINES - 8)
        top = min(top_by_tab[tab], max(0, len(rows) - height))
        if idx < top: top = idx
        if idx >= top + height: top = idx - height + 1
        top_by_tab[tab] = top

        stdscr.erase()
        draw_tabs(stdscr, active)
        draw_rows(stdscr, rows, idx, top)
        addstr(stdscr, curses.LINES - 2, 0, "─" * max(0, curses.COLS - 1), color(CP_MUTED))
        addstr(stdscr, curses.LINES - 1, 0, footer_for(tab, rows[idx]), color(CP_MUTED))
        stdscr.refresh()

        ch = safe_getch(stdscr)
        if ch == curses.KEY_RESIZE:
            curses.update_lines_cols()
            stdscr.clear()
            continue
        if ch in (3, ord('q')):
            if dirty: state.save()
            return
        if ch == ord('D'):
            if tab == "Run" or delete_or_reset(state, rows[idx]): return
        elif ch in (curses.KEY_RIGHT,):
            active = (active + 1) % len(TABS)
        elif ch in (curses.KEY_LEFT,):
            active = (active - 1) % len(TABS)
        elif ch in (9,):
            active = (active + 1) % len(TABS)
        elif ch in (curses.KEY_UP, ord('k'), 16):
            idx_by_tab[tab] = move_selection(rows, idx, -1)
        elif ch in (curses.KEY_DOWN, ord('j'), 14):
            idx_by_tab[tab] = move_selection(rows, idx, 1)
        elif ch == ord(' ') and rows[idx].key.startswith("category:"):
            cycle_category(state, rows[idx].key[9:])
        elif ch == ord(' ') and rows[idx].key == "env_file":
            if state.env_file:
                state.env_file_enabled = not state.env_file_enabled
            else:
                activate_row(stdscr, state, rows[idx])
        elif ch in ENTER_KEYS and rows[idx].key.startswith("category:"):
            activate_row(stdscr, state, rows[idx])
        elif is_activate_key(ch):
            if activate_row(stdscr, state, rows[idx]): return

def first_run_ui(stdscr, state: State, original: State) -> None:
    launch_program(stdscr, state)
    main_ui(stdscr, state, original)


def main() -> int:
    args = sys.argv[1:]
    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0
    if "--ensure-safehouse" in args:
        # Used by install.sh right after installing safehouse+, so the
        # safehouse dependency check/install happens as part of one
        # continuous install flow instead of waiting for first real use.
        return 0 if ensure_safehouse_available() else 1

    if not ensure_safehouse_available():
        print("safehouse+ cannot continue without safehouse.", file=sys.stderr)
        return 1

    state = State.load()
    original = copy.deepcopy(state)
    show_menu_first = False
    if "--menu" in args:
        show_menu_first = True
        args = [arg for arg in args if arg != "--menu"]
    once = False
    if "--once" in args:
        once = True
        args = [arg for arg in args if arg != "--once"]
    script = False
    if "--script" in args:
        once = True
        script = True
        args = [arg for arg in args if arg != "--script"]

    if once:
        if args:
            state.command = args
        return run_once(state, quiet=script)

    try:
        if args:
            state.command = args
            if show_menu_first:
                curses.wrapper(main_ui, state, original)
            else:
                # If the user supplied a command on this invocation, launch it first.
                # This keeps `safehouse+ pi` behaving like `safehouse pi`, then returns
                # to the menu for tweaks/restarts after the process exits.
                curses.wrapper(first_run_ui, state, original)
        else:
            curses.wrapper(main_ui, state, original)
    except KeyboardInterrupt:
        if state.settings_dict() != original.settings_dict():
            state.save()
        return 130
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
