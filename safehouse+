CONFIG_PATH = Path.cwd() / ".safehouse-plus.json"
SAFEHOUSE = os.environ.get("SAFEHOUSE", "safehouse")
LAST_RESUME_COMMAND: List[str] | None = None

CP_TITLE = 1
CP_MUTED = 2
CP_SELECTED = 3
CP_GOOD = 4
CP_WARN = 5
CP_BAD = 6
CP_ACCENT = 7


def init_colors() -> None:
    if not curses.has_colors():
        return
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(CP_TITLE, curses.COLOR_CYAN, -1)
    curses.init_pair(CP_MUTED, curses.COLOR_WHITE, -1)
    curses.init_pair(CP_SELECTED, curses.COLOR_BLACK, curses.COLOR_CYAN)
    curses.init_pair(CP_GOOD, curses.COLOR_GREEN, -1)
    curses.init_pair(CP_WARN, curses.COLOR_YELLOW, -1)
    curses.init_pair(CP_BAD, curses.COLOR_RED, -1)
    curses.init_pair(CP_ACCENT, curses.COLOR_MAGENTA, -1)


def color(pair: int, extra: int = 0) -> int:
    return (curses.color_pair(pair) if curses.has_colors() else 0) | extra


def addstr(win, y: int, x: int, text: str, attr: int = 0) -> None:
    try:
        win.addstr(y, x, text[: max(0, curses.COLS - x - 1)], attr)
    except curses.error:
        pass


def shell_join(argv: List[str]) -> str:
    return " ".join(shlex.quote(a) for a in argv)


def command_available(command: str) -> bool:
    if "/" in command:
        return os.path.isfile(os.path.expanduser(command)) and os.access(os.path.expanduser(command), os.X_OK)
    return shutil.which(command) is not None


def ensure_safehouse_available() -> bool:
    if command_available(SAFEHOUSE):
        return True

    install_commands = [
        "mkdir -p ~/.local/bin",
        "curl -fsSL https://github.com/eugene1g/agent-safehouse/releases/latest/download/safehouse.sh \\",
        "  -o ~/.local/bin/safehouse",
        "chmod +x ~/.local/bin/safehouse",
    ]
    print("safehouse was not found in PATH.\n")
    print("Should I install safehouse? This will run:\n")
    print("\n".join(install_commands))
    answer = input("\nInstall safehouse? [y/N] ").strip().lower()
    if answer not in {"y", "yes"}:
        return False

    target = Path.home() / ".local" / "bin" / "safehouse"
    target.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run([
        "curl", "-fsSL",
        "https://github.com/eugene1g/agent-safehouse/releases/latest/download/safehouse.sh",
        "-o", str(target),
    ], check=True)
    target.chmod(0o755)
    return command_available(SAFEHOUSE)


def split_colon(paths: List[str]) -> str:
    return ":".join(p for p in paths if p)


def sb_quote(s: str) -> str:
    return json.dumps(os.path.expanduser(s))


@dataclass
class State:
    command: List[str] = field(default_factory=list)
    enabled: List[str] = field(default_factory=list)
    ro_paths: List[str] = field(default_factory=list)
    rw_paths: List[str] = field(default_factory=list)
    deny_paths: List[str] = field(default_factory=list)
    paths: List[str] = field(default_factory=list)  # all paths shown in the path editor, including off
    network: bool = True
    workdir: str = ""
    env_mode: str = "sanitized"  # sanitized | full
    env_pass: List[str] = field(default_factory=list)
    trust_workdir_config: bool = False

    @classmethod
    def load(cls) -> "State":
        if CONFIG_PATH.exists():
            try:
                data = json.loads(CONFIG_PATH.read_text())
                return cls(**{k: v for k, v in data.items() if k in cls.__dataclass_fields__})
            except Exception:
                pass
        return cls()

    def save(self) -> None:
        CONFIG_PATH.write_text(json.dumps(asdict(self), indent=2) + "\n")

    def safehouse_args(self, append_profile: str | None = None) -> List[str]:
        args: List[str] = []
        if self.enabled:
            args += [f"--enable={','.join(self.enabled)}"]
        if self.ro_paths:
            args += [f"--add-dirs-ro={split_colon(self.ro_paths)}"]
        if self.rw_paths:
            args += [f"--add-dirs={split_colon(self.rw_paths)}"]
        if self.workdir:
            args += [f"--workdir={self.workdir}"]
        if self.trust_workdir_config:
            args += ["--trust-workdir-config"]
        if self.env_mode == "full":
            args += ["--env"]
        if self.env_pass:
            args += [f"--env-pass={','.join(self.env_pass)}"]
        if append_profile:
            args += [f"--append-profile={append_profile}"]
        return args

    def make_append_profile(self) -> str | None:
        rules: List[str] = []
        if not self.network:
            rules.append("(deny network*)")
        if self.deny_paths:
            entries = []
            for p in self.deny_paths:
                expanded = os.path.expanduser(p)
                kind = "subpath" if p.endswith("/") or os.path.isdir(expanded) else "literal"
                entries.append(f"    ({kind} {sb_quote(p)})")
            rules.append("(deny file-read* file-write*\n" + "\n".join(entries) + "\n)")
        if not rules:
            return None
        f = tempfile.NamedTemporaryFile("w", prefix="safehouse-plus-", suffix=".sb", delete=False)
        f.write(";; generated by safehouse+\n" + "\n\n".join(rules) + "\n")
        f.close()
        return f.name

    def launch_argv(self, command: List[str] | None = None) -> tuple[List[str], str | None]:
        profile = self.make_append_profile()
        return [SAFEHOUSE] + self.safehouse_args(profile) + ["--"] + (command or self.command), profile


ENTER_KEYS = (10, 13)
ACTIVATE_KEYS = ENTER_KEYS + (ord(' '),)


def safe_getch(win) -> int:
    try:
        return win.getch()
    except KeyboardInterrupt:
        return 3  # Ctrl-c


def is_activate_key(ch: int) -> bool:
    return ch in ACTIVATE_KEYS


def prompt(stdscr, title: str, initial: str = "", complete_path: bool = False) -> str | None:
    """Small single-line editor with a visible cursor and Emacs-style motion."""
    def word_left(p: int) -> int:
        while p > 0 and buf[p - 1].isspace():
            p -= 1
        while p > 0 and not buf[p - 1].isspace():
            p -= 1
        return p

    def word_right(p: int) -> int:
        n = len(buf)
        while p < n and not buf[p].isspace():
            p += 1
        while p < n and buf[p].isspace():
            p += 1
        return p

    def read_after_escape() -> int:
        # ESC alone cancels. ESC-b / ESC-f are Meta-b / Meta-f word motion.
        win.nodelay(True)
        try:
            nxt = safe_getch(win)
        finally:
            win.nodelay(False)
        return nxt

    def complete_path_at_cursor() -> str:
        nonlocal pos
        text = "".join(buf)
        start = max(text.rfind(" ", 0, pos), text.rfind(":", 0, pos)) + 1
        token = text[start:pos]
        expanded = os.path.expanduser(token or "")
        dirname = os.path.dirname(expanded) or "."
        basename = os.path.basename(expanded)
        try:
            names = os.listdir(dirname)
        except OSError:
            return "no matches"
        matches = [name + ("/" if os.path.isdir(os.path.join(dirname, name)) else "") for name in names if name.startswith(basename)]
        if not matches:
            return "no matches"
        token_dir = os.path.dirname(token)
        if len(matches) == 1:
            completed = os.path.join(token_dir, matches[0]) if token_dir else matches[0]
            del buf[start:pos]
            buf[start:start] = list(completed)
            pos = start + len(completed)
            return ""
        common = os.path.commonprefix(matches)
        if common and common != basename:
            completed = os.path.join(token_dir, common) if token_dir else common
            del buf[start:pos]
            buf[start:start] = list(completed)
            pos = start + len(completed)
        return "matches: " + "  ".join(matches[:6]) + (" …" if len(matches) > 6 else "")

    h, w = stdscr.getmaxyx()
    width = max(20, w - 4)
    win_height = 4 if complete_path else 3
    win = curses.newwin(win_height, width, max(0, h // 2 - 1), 2)
    win.keypad(True)
    buf = list(initial)
    pos = len(buf)
    scroll = 0
    hint = "Tab completes paths" if complete_path else ""
    old_cursor = curses.curs_set(1)
    try:
        while True:
            inner = width - 4
            if pos < scroll:
                scroll = pos
            elif pos > scroll + inner:
                scroll = pos - inner
            visible = "".join(buf[scroll: scroll + inner])
            win.erase()
            win.box()
            win.addstr(0, 2, f" {title} ")
            win.addstr(1, 2, visible.ljust(inner))
            if complete_path:
                win.addstr(2, 2, hint[:inner].ljust(inner), color(CP_MUTED))
            win.move(1, 2 + pos - scroll)
            win.refresh()
            ch = safe_getch(win)
            if ch == 3:  # Ctrl-c cancels this input, not safehouse+
                return None
            if ch in ENTER_KEYS:
                return "".join(buf)
            if ch == 27:  # ESC / Meta prefix
                nxt = read_after_escape()
                if nxt in (ord('b'), ord('B')):
                    pos = word_left(pos)
                elif nxt in (ord('f'), ord('F')):
                    pos = word_right(pos)
                elif nxt in (127, 8):  # Meta-backspace: delete previous word
                    new_pos = word_left(pos)
                    del buf[new_pos:pos]
                    pos = new_pos
                elif nxt == -1:
                    return None
                continue
            if ch in (curses.KEY_LEFT, 2):  # left / Ctrl-b
                pos = max(0, pos - 1)
            elif ch in (curses.KEY_RIGHT, 6):  # right / Ctrl-f
                pos = min(len(buf), pos + 1)
            elif ch in (curses.KEY_HOME, 1):  # home / Ctrl-a
                pos = 0
            elif ch in (curses.KEY_END, 5):  # end / Ctrl-e
                pos = len(buf)
            elif complete_path and ch == 9:  # Tab: path completion
                hint = complete_path_at_cursor()
            elif ch == 23:  # Ctrl-w: delete previous word
                new_pos = word_left(pos)
                del buf[new_pos:pos]
                pos = new_pos
            elif ch == 11:  # Ctrl-k: kill to end
                del buf[pos:]
            elif ch == 21:  # Ctrl-u: kill whole line before cursor
                del buf[:pos]
                pos = 0
            elif ch in (4, curses.KEY_DC):  # Ctrl-d / Delete: delete char under cursor
                if pos < len(buf):
                    del buf[pos]
            elif ch in (curses.KEY_BACKSPACE, 127, 8):
                if pos > 0:
                    del buf[pos - 1]
                    pos -= 1
            elif 32 <= ch <= 126:
                buf.insert(pos, chr(ch))
                pos += 1
    finally:
        curses.curs_set(old_cursor)


def choose_feature(stdscr, state: State) -> None:
    idx = 0
    while True:
        stdscr.erase()
        stdscr.addstr(0, 0, "Toggle features: Ctrl-p/Ctrl-n navigate, Enter/Space toggle, q/backspace return")
        h, _ = stdscr.getmaxyx()
        for i, feat in enumerate(FEATURES[max(0, idx - h + 3): max(0, idx - h + 3) + h - 2], start=max(0, idx - h + 3)):
            mark = "[x]" if feat in state.enabled else "[ ]"
            prefix = "> " if i == idx else "  "
            stdscr.addstr(i - max(0, idx - h + 3) + 1, 0, f"{prefix}{mark} {feat}")
        ch = safe_getch(stdscr)
        if ch in (3, ord('q'), 27, curses.KEY_BACKSPACE, 127):
            return
        if ch in (curses.KEY_UP, ord('k'), 16):  # Ctrl-p
            idx = max(0, idx - 1)
        elif ch in (curses.KEY_DOWN, ord('j'), 14):  # Ctrl-n
            idx = min(len(FEATURES) - 1, idx + 1)
        elif is_activate_key(ch):
            feat = FEATURES[idx]
            if feat in state.enabled:
                state.enabled.remove(feat)
            else:
                state.enabled.append(feat)
                state.enabled.sort()


def edit_paths(stdscr, state: State) -> None:
    def mode_for(path: str) -> str:
        if path in state.rw_paths:
            return "rw"
        if path in state.ro_paths:
            return "ro"
        if path in state.deny_paths:
            return "deny"
        return "off"

    def set_mode(path: str, mode: str) -> None:
        if path not in state.paths:
            state.paths.append(path)
        for paths in (state.ro_paths, state.rw_paths, state.deny_paths):
            while path in paths:
                paths.remove(path)
        if mode == "ro":
            state.ro_paths.append(path)
        elif mode == "rw":
            state.rw_paths.append(path)
        elif mode == "deny":
            state.deny_paths.append(path)

    def cycle(path: str) -> None:
        modes = ["ro", "rw", "deny", "off"]
        set_mode(path, modes[(modes.index(mode_for(path)) + 1) % len(modes)])

    idx = 0
    while True:
        paths = sorted(set(state.paths + state.ro_paths + state.rw_paths + state.deny_paths))
        idx = min(idx, max(0, len(paths) - 1))
        stdscr.erase()
        addstr(stdscr, 0, 0, "Paths: Enter/Space toggle ro→rw→deny→off, a add, e edit, d delete, q return", color(CP_TITLE, curses.A_BOLD))
        if not paths:
            addstr(stdscr, 2, 2, "(empty)", color(CP_MUTED))
        for i, path in enumerate(paths[: curses.LINES - 2]):
            mode = mode_for(path)
            attr = color(CP_SELECTED) if i == idx else 0
            mode_attr = {"ro": color(CP_ACCENT), "rw": color(CP_GOOD), "deny": color(CP_BAD)}.get(mode, 0)
            prefix = "> " if i == idx else "  "
            addstr(stdscr, i + 1, 0, prefix, attr)
            addstr(stdscr, i + 1, 2, f"[{mode:4}] ", mode_attr | (curses.A_BOLD if mode != "off" else 0))
            addstr(stdscr, i + 1, 9, path, attr)
        ch = safe_getch(stdscr)
        if ch in (3, ord('q'), 27, curses.KEY_BACKSPACE, 127):
            return
        if ch in (curses.KEY_UP, ord('k'), 16):
            idx = max(0, idx - 1)
        elif ch in (curses.KEY_DOWN, ord('j'), 14):
            idx = min(max(0, len(paths) - 1), idx + 1)
        elif is_activate_key(ch) and paths:
            cycle(paths[idx])
        elif ch == ord('a'):
            s = prompt(stdscr, "Add path", "", complete_path=True)
            if s:
                set_mode(s, "rw")
        elif ch == ord('e') and paths:
            old = paths[idx]
            s = prompt(stdscr, "Edit path", old, complete_path=True)
            if s:
                old_mode = mode_for(old)
                set_mode(old, "off")
                set_mode(s, old_mode if old_mode != "off" else "rw")
        elif ch == ord('d') and paths:
            path = paths[idx]
            set_mode(path, "off")
            while path in state.paths:
                state.paths.remove(path)
            idx = min(idx, max(0, len(paths) - 2))


def edit_list(stdscr, title: str, items: List[str]) -> None:
    idx = 0
    while True:
        stdscr.erase()
        stdscr.addstr(0, 0, f"{title}: Ctrl-p/Ctrl-n navigate, a add, e edit, d delete, q return")
        if not items:
            stdscr.addstr(2, 2, "(empty)")
        for i, item in enumerate(items[: curses.LINES - 2]):
            prefix = "> " if i == idx else "  "
            stdscr.addstr(i + 1, 0, f"{prefix}{item}"[: curses.COLS - 1])
        ch = safe_getch(stdscr)
        if ch in (3, ord('q'), 27, curses.KEY_BACKSPACE, 127):
            return
        if ch in (curses.KEY_UP, ord('k'), 16):  # Ctrl-p
            idx = max(0, idx - 1)
        elif ch in (curses.KEY_DOWN, ord('j'), 14):  # Ctrl-n
            idx = min(max(0, len(items) - 1), idx + 1)
        elif ch == ord('a'):
            s = prompt(stdscr, f"Add {title}", "")
            if s:
                items.append(s)
        elif ch == ord('e') and items:
            s = prompt(stdscr, f"Edit {title}", items[idx])
            if s is not None and s != "":
                items[idx] = s
        elif ch == ord('d') and items:
            del items[idx]
            idx = min(idx, max(0, len(items) - 1))


def show_text(stdscr, title: str, text: str) -> None:
    lines = text.splitlines() or [""]
    top = 0
    while True:
        stdscr.erase()
        stdscr.addstr(0, 0, f"{title} - q return, Ctrl-p/Ctrl-n or arrows scroll")
        h, w = stdscr.getmaxyx()
        for y, line in enumerate(lines[top: top + h - 1], start=1):
            stdscr.addstr(y, 0, line[: w - 1])
        ch = safe_getch(stdscr)
        if ch in (3, ord('q'), 27, curses.KEY_BACKSPACE, 127):
            return
        if ch in (curses.KEY_DOWN, ord('j'), 14):  # Ctrl-n
            top = min(max(0, len(lines) - 1), top + 1)
        elif ch in (curses.KEY_UP, ord('k'), 16):  # Ctrl-p
            top = max(0, top - 1)
        elif ch == curses.KEY_NPAGE:
            top = min(max(0, len(lines) - 1), top + h - 2)
        elif ch == curses.KEY_PPAGE:
            top = max(0, top - h + 2)


def run_capture(args: List[str]) -> str:
    try:
        p = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=20)
        return p.stdout
    except Exception as e:
        return f"Failed to run {shell_join(args)}\n{e}"


ANSI_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
RESUME_PATTERNS = [
    re.compile(r"To resume this session:\s*(.+)", re.IGNORECASE),
    re.compile(r"To resume, run:\s*(.+)", re.IGNORECASE),
    re.compile(r"Run\s+[`'\"]?(.+?(?:resume|--resume|--continue|--session).+?)[`'\"]?\s+to resume", re.IGNORECASE),
]


def detect_resume_command(output: str) -> List[str] | None:
    clean = ANSI_RE.sub("", output.replace("\r", "\n"))
    for line in reversed(clean.splitlines()):
        line = line.strip()
        for pattern in RESUME_PATTERNS:
            m = pattern.search(line)
            if not m:
                continue
            cmd = m.group(1).strip().strip("`'")
            try:
                parsed = shlex.split(cmd)
            except ValueError:
                continue
            if parsed:
                return parsed
    return None


def terminal_winsize() -> bytes:
    try:
        return fcntl.ioctl(sys.stdout.fileno(), termios.TIOCGWINSZ, b"\0" * 8)
    except OSError:
        rows, cols = shutil.get_terminal_size((80, 24)).lines, shutil.get_terminal_size((80, 24)).columns
        return struct.pack("HHHH", rows, cols, 0, 0)


def run_pty_capture(argv: List[str]) -> str:
    """Run argv in a fresh PTY, with the real terminal size/mode restored."""
    captured = bytearray()
    max_capture = 250_000
    pid, master_fd = pty.fork()

    if pid == 0:
        os.execvp(argv[0], argv)

    def sync_winsize(*_ignored) -> None:
        try:
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, terminal_winsize())
        except OSError:
            pass

    sync_winsize()
    old_winch = signal.getsignal(signal.SIGWINCH)
    signal.signal(signal.SIGWINCH, sync_winsize)

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    old_term = None
    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    try:
        while True:
            ready, _, _ = select.select([master_fd, stdin_fd], [], [])
            if master_fd in ready:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    break
                if not data:
                    break
                captured.extend(data)
                if len(captured) > max_capture:
                    del captured[: len(captured) - max_capture]
                os.write(stdout_fd, data)
            if stdin_fd in ready:
                data = os.read(stdin_fd, 4096)
                if data:
                    os.write(master_fd, data)
            try:
                done, _status = os.waitpid(pid, os.WNOHANG)
                if done == pid:
                    break
            except ChildProcessError:
                break
    finally:
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_term)
        signal.signal(signal.SIGWINCH, old_winch)
        try:
            os.close(master_fd)
        except OSError:
            pass
        try:
            os.waitpid(pid, 0)
        except ChildProcessError:
            pass

    return captured.decode(errors="replace")


def launch_program(stdscr, state: State, command: List[str] | None = None) -> None:
    global LAST_RESUME_COMMAND
    command_to_run = command or state.command
    if not command_to_run:
        s = prompt(stdscr, "Command", "")
        if not s:
            return
        state.command = shlex.split(s)
        command_to_run = state.command
    argv, profile = state.launch_argv(command_to_run)
    curses.def_prog_mode()
    curses.endwin()
    try:
        curses.reset_shell_mode()
    except curses.error:
        pass
    print(f"\n$ {shell_join(argv)}\n")
    try:
        output = run_pty_capture(argv)
        detected = detect_resume_command(output)
        if detected:
            LAST_RESUME_COMMAND = detected
    finally:
        if profile:
            try: os.unlink(profile)
            except OSError: pass
        curses.reset_prog_mode()
        stdscr.refresh()


def activate_main_choice(stdscr, state: State, choice: str) -> bool:
    """Run one main-menu action. Return True when the menu should exit."""
    if choice == "resume" and LAST_RESUME_COMMAND:
        launch_program(stdscr, state, LAST_RESUME_COMMAND)
    elif choice == "run":
        launch_program(stdscr, state)
    elif choice == "edit_command":
        s = prompt(stdscr, "Command", shell_join(state.command))
        if s is not None:
            state.command = shlex.split(s) if s else []
    elif choice == "features":
        choose_feature(stdscr, state)
    elif choice == "network":
        state.network = not state.network
    elif choice == "paths":
        edit_paths(stdscr, state)
    elif choice == "workdir":
        s = prompt(stdscr, "Workdir (empty = safehouse default)", state.workdir, complete_path=True)
        if s is not None:
            state.workdir = s
    elif choice == "env":
        state.env_mode = "full" if state.env_mode != "full" else "sanitized"
    elif choice == "env_pass":
        edit_list(stdscr, "env-pass names", state.env_pass)
    elif choice == "command":
        argv, profile = state.launch_argv()
        show_text(stdscr, "safehouse command", shell_join(argv) + (f"\n\nappend profile: {profile}" if profile else ""))
        if profile:
            try:
                os.unlink(profile)
            except OSError:
                pass
    elif choice == "explain":
        prof = state.make_append_profile()
        show_text(stdscr, "explain", run_capture([SAFEHOUSE] + state.safehouse_args(prof) + ["--explain"]))
        if prof:
            try:
                os.unlink(prof)
            except OSError:
                pass
    elif choice == "save":
        state.save()
        return True
    elif choice == "discard":
        return True
    return False


def main_ui(stdscr, state: State, original: State | None = None) -> None:
    init_colors()
    curses.curs_set(0)
    idx = 0
    original_snapshot = asdict(original or copy.deepcopy(state))
    while True:
        cmd = shell_join(state.command) if state.command else "(none)"
        dirty = asdict(state) != original_snapshot
        menu = [
            ("run", "Run / restart program", cmd),
            ("edit_command", "Edit program command", cmd),
            ("features", "Toggle optional features", f"{len(state.enabled)} enabled"),
            ("network", f"[{'x' if state.network else ' '}] Network access", ""),
            ("paths", "Edit path rules", f"ro/rw/deny: {len(state.ro_paths)}/{len(state.rw_paths)}/{len(state.deny_paths)}"),
            ("workdir", "Edit workdir", state.workdir or f"(default: {Path.cwd()})"),
            ("env", f"[{'x' if state.env_mode == 'full' else ' '}] Full environment", ""),
            ("env_pass", "Edit env-pass variables", ",".join(state.env_pass) or "(none)"),
            ("command", "View generated safehouse command", ""),
            ("explain", "View safehouse --explain", ""),
            ("save", "Save and Quit (q/Ctrl-C)" + (" *" if dirty else ""), ""),
            ("discard", "Discard and Quit", ""),
        ]
        if LAST_RESUME_COMMAND:
            menu.insert(0, ("resume", "Resume detected session", shell_join(LAST_RESUME_COMMAND)))
        idx = min(idx, len(menu) - 1)
        stdscr.erase()
        addstr(stdscr, 0, 0, "safehouse+", color(CP_TITLE, curses.A_BOLD))
        for i, (key, label, side) in enumerate(menu):
            attr = color(CP_SELECTED) if i == idx else 0
            label_attr = attr
            if key == "discard":
                label_attr |= color(CP_BAD) if i != idx else 0
            elif key == "save" and dirty:
                label_attr |= color(CP_GOOD, curses.A_BOLD) if i != idx else curses.A_BOLD
            elif key in ("network", "env"):
                label_attr |= color(CP_GOOD) if "[x]" in label and i != idx else 0
            prefix = "> " if i == idx else "  "
            y = i + 2
            addstr(stdscr, y, 0, prefix, attr)
            addstr(stdscr, y, 2, label, label_attr)
            if side:
                side_x = 32 if curses.COLS >= 90 else 24
                addstr(stdscr, y, side_x, side, color(CP_ACCENT) if key in ("run", "edit_command", "resume") else color(CP_MUTED))
        ch = safe_getch(stdscr)
        if ch in (3, ord('q'), 27):
            state.save(); return
        if ch == ord('r') and LAST_RESUME_COMMAND:
            if activate_main_choice(stdscr, state, "resume"):
                return
        elif ch in (curses.KEY_UP, ord('k'), 16):
            idx = max(0, idx - 1)
        elif ch in (curses.KEY_DOWN, ord('j'), 14):
            idx = min(len(menu) - 1, idx + 1)
        elif is_activate_key(ch):
            if activate_main_choice(stdscr, state, menu[idx][0]):
                return


def first_run_ui(stdscr, state: State, original: State) -> None:
    launch_program(stdscr, state)
    main_ui(stdscr, state, original)


def main() -> int:
    if not ensure_safehouse_available():
        print("safehouse+ cannot continue without safehouse.", file=sys.stderr)
        return 1

    state = State.load()
    original = copy.deepcopy(state)
    args = sys.argv[1:]
    show_menu_first = False
    if "--menu" in args:
        show_menu_first = True
        args = [arg for arg in args if arg != "--menu"]

    try:
        if args:
            state.command = args
            if show_menu_first:
                curses.wrapper(main_ui, state, original)
            else:
                # If the user supplied a command on this invocation, launch it first.
                # This keeps `safehouse+ pi` behaving like `safehouse pi`, then returns
                # to the menu for tweaks/restarts after the process exits.
                curses.wrapper(first_run_ui, state, original)
        else:
            curses.wrapper(main_ui, state, original)
    except KeyboardInterrupt:
        state.save()
        return 130
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
